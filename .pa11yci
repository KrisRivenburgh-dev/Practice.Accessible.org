{
  "defaults": {
    "standard": "WCAG2AA",
    "runners": ["axe", "htmlcs"],
    "timeout": 40000,
    "wait": 600,
    "comment": "The decorative hero illustration is aria-hidden; axe cannot resolve SVG text backgrounds, so it is excluded from the automated contrast check.",
    "hideElements": ".hero-art svg",
    "chromeLaunchConfig": { "args": ["--no-sandbox", "--disable-dev-shm-usage"] }
  },
  "urls": [
    "http://localhost:4321/",
    "http://localhost:4321/explore",
    "http://localhost:4321/about",
    "http://localhost:4321/keyboard-fixed",
    "http://localhost:4321/keyboard-breakdown",
    "http://localhost:4321/accessibility",
    "http://localhost:4321/privacy",
    "http://localhost:4321/terms",
    "http://localhost:4321/404"
  ]
}
