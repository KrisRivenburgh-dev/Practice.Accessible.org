---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL;
const join = (p) => (base + p).replace(/\/{2,}/g, '/');
---

<Base
  title="Terms of use · Accessible.org"
  description="Terms of use for this free educational accessibility practice site, a sub-site of Accessible.org."
>
  <section class="lesson-head wrap">
    <p class="kicker">Terms</p>
    <h1>Terms of use</h1>
    <p class="lead">
      A free educational resource from Accessible.org, provided to help you learn web accessibility.
    </p>
    <p class="doc-meta">Last updated 23 June 2026</p>
  </section>

  <div class="wrap" style="padding-bottom: clamp(3rem, 7vw, 5rem);">
    <div class="prose">
      <h2>Using this site</h2>
      <p>
        You are welcome to use this site to learn about accessibility, and to reuse the corrected
        code patterns shown on the Fixed and Breakdown pages in your own work. Please do not reuse
        the deliberately broken patterns from the Testing pages, which exist only as training
        examples. See the <a href={join('/accessibility')}>accessibility statement</a> for details.
      </p>

      <h2>Fictional content</h2>
      <p>
        The example product called "Northwind", along with its pricing, names, and copy, is
        fictional and used only for demonstration. Nothing on the practice pages is a real offer.
      </p>

      <h2>No warranty</h2>
      <p>
        This site is provided "as is", without warranties of any kind. The guidance here is
        educational and is not a substitute for a professional accessibility audit or legal advice.
        For a formal audit or a VPAT, see <a href="https://accessible.org" rel="noopener">Accessible.org</a>.
      </p>

      <h2>Limitation of liability</h2>
      <p>
        To the extent permitted by law, Accessible.org is not liable for any loss arising from your
        use of this site or the example code.
      </p>

      <h2>The parent organisation</h2>
      <p>
        This is a learning sub-site of <a href="https://accessible.org" rel="noopener">Accessible.org</a>.
        The organisation's full terms apply where relevant. Visit Accessible.org for more.
      </p>
    </div>
  </div>
</Base>
