---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
const base = import.meta.env.BASE_URL;
const join = (p) => (base + p).replace(/\/{2,}/g, '/');
---

<Base
  title="Page not found · Accessible.org"
  description="That page does not exist. Head back to the home page or browse the lessons."
>
  <section class="wrap" style="padding-block: clamp(4rem, 12vw, 8rem);">
    <p class="kicker">Error 404</p>
    <h1 style="margin-top: 0.5rem;">This page isn't here.</h1>
    <p class="lead" style="margin-top: 1.25rem;">
      The page you were after does not exist, or it moved. No barriers intended this time, it is
      just missing. Let's get you back on track.
    </p>
    <div class="btn-row" style="margin-top: 2rem;">
      <a class="btn btn-primary" href={join('/explore')}>
        Explore the lessons <Icon name="arrow" size={18} class="icon" />
      </a>
      <a class="btn btn-ghost" href={join('/')}>Back to home</a>
    </div>
  </section>
</Base>
