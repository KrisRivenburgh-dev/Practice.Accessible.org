---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import MockSite from '../components/MockSite.astro';
const base = import.meta.env.BASE_URL;
const join = (p) => (base + p).replace(/\/{2,}/g, '/');
---

<Base
  title="Keyboard Practice · Accessible.org"
  description="A full product website with real keyboard barriers hidden across it. Try to operate the whole page with the keyboard alone and find every issue."
>
  <section class="lesson-head wrap">
    <p class="kicker">Lesson 01 · Keyboard · Practice</p>
    <h1>Find the barriers.</h1>
    <p class="lead">
      The page below is for Northwind, a fictional product. It looks finished and it works with a
      mouse. Five keyboard barriers are hidden across it. Your job is to find them.
    </p>

    <div class="callout">
      <span class="c-icon"><Icon name="scan" class="icon" /></span>
      <div>
        <h2>Your task</h2>
        <p>
          Put the mouse down. Using only <kbd>Tab</kbd>, <kbd>Shift</kbd>+<kbd>Tab</kbd>, <kbd>Enter</kbd>, <kbd>Space</kbd>, the arrow keys and <kbd>Esc</kbd>, try to do everything
          on the page: start a trial, watch the demo, switch the billing period, open the currency
          menu, and request an invite. The status line at the bottom reports each action that fires.
        </p>
        <p>
          Note everything you cannot reach, cannot see, or cannot trigger. When you are ready, <a class="inline" href={join('/keyboard-breakdown')}>open the breakdown</a> to check what you found.
        </p>
      </div>
    </div>
  </section>

  <div class="wrap" style="padding-bottom: clamp(3rem, 7vw, 5rem);">
    <MockSite mode="broken" />

    <section class="spotcheck" aria-labelledby="spotcheck-h">
      <div class="spotcheck-head">
        <span class="step-icon"><Icon name="list" class="icon" /></span>
        <div>
          <h2 id="spotcheck-h">Spot check</h2>
          <p>How many barriers did you find? Make your guess, then reveal the count before you read the breakdown.</p>
        </div>
      </div>
      <div class="spotcheck-row">
        <div>
          <label class="spotcheck-label" for="found">Barriers you found</label>
          <input id="found" class="spotcheck-input" type="number" min="0" max="10" value="0" inputmode="numeric" />
        </div>
        <button class="btn btn-primary" type="button" id="revealBtn">Reveal</button>
      </div>
      <p class="spotcheck-result" id="spotResult" role="status"></p>
    </section>

    <div class="switch" style="margin-top: 2.5rem;">
      <a class="btn btn-primary" href={join('/keyboard-breakdown')}>
        Done hunting? Open the breakdown <Icon name="arrow" size={18} class="icon" />
      </a>
      <a class="btn btn-ghost" href={join('/keyboard-fixed')}>Skip to the fixed page</a>
    </div>
  </div>

  <script is:inline>
    (function () {
      const TOTAL = 5;
      const btn = document.getElementById('revealBtn');
      const input = document.getElementById('found');
      const result = document.getElementById('spotResult');
      if (!btn || !input || !result) return;
      const reveal = () => {
        const n = Math.max(0, Math.min(10, parseInt(input.value, 10) || 0));
        let msg;
        if (n >= TOTAL) msg = 'This page hides ' + TOTAL + ' barriers, and you counted ' + n + '. Nice work. Open the breakdown to confirm each one.';
        else if (n === 0) msg = 'This page hides ' + TOTAL + ' barriers. Have another look, or open the breakdown to see them all.';
        else {
          const left = TOTAL - n;
          msg = 'This page hides ' + TOTAL + ' barriers. You found ' + n + ', so ' + left + (left === 1 ? ' is' : ' are') + ' still hiding. Open the breakdown to see them all.';
        }
        result.textContent = msg;
      };
      btn.addEventListener('click', reveal);
      input.addEventListener('keydown', (e) => { if (e.key === 'Enter') { e.preventDefault(); reveal(); } });
    })();
  </script>
</Base>
